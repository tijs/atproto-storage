{
  "$schema": "https://jsr.io/schema/config-file.v1.json",
  "name": "@tijs/atproto-storage",
  "version": "1.1.0",
  "license": "MIT",
  "exports": "./mod.ts",
  "publish": {
    "include": [
      "mod.ts",
      "src/**/*.ts",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "**/*.test.ts",
      "npm/",
      "_build_npm.ts"
    ]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.16"
  },
  "lint": {
    "exclude": ["_build_npm.ts"]
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true
  },
  "tasks": {
    "test": "deno test --allow-all --unstable-kv src/",
    "check": "deno check mod.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "quality": "deno fmt && deno lint && deno check mod.ts",
    "ci": "deno task quality && deno task test",
    "build:npm": "deno run -A _build_npm.ts"
  }
}
